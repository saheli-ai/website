<section class="relative min-h-screen overflow-hidden bg-bg-dark">
  <!-- Prismatic gradient orbs -->
  <div class="absolute inset-0 overflow-hidden">
    <div class="absolute -left-32 top-1/4 h-[500px] w-[500px] rounded-full bg-gradient-to-br from-primary/30 via-sky/20 to-transparent blur-[100px] animate-pulse-glow"></div>
    <div class="absolute -right-32 top-1/3 h-[600px] w-[600px] rounded-full bg-gradient-to-bl from-rose/25 via-iris/20 to-transparent blur-[100px] animate-pulse-glow" style="animation-delay: 1.5s;"></div>
    <div class="absolute bottom-0 left-1/3 h-[400px] w-[400px] rounded-full bg-gradient-to-t from-gold/20 via-primary/10 to-transparent blur-[100px] animate-pulse-glow" style="animation-delay: 3s;"></div>
  </div>

  <div class="relative mx-auto max-w-6xl px-6 pb-24 pt-32 sm:pt-40 lg:pt-48">
    <div class="grid items-center gap-16 lg:grid-cols-2">
      <!-- Copy -->
      <div class="max-w-xl">
        <div class="animate-fade-up mb-6 inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/5 px-4 py-1.5 backdrop-blur-sm">
          <span class="h-2 w-2 rounded-full bg-gradient-to-r from-primary to-sky"></span>
          <span class="text-xs font-medium tracking-wide text-white/70">AI-Powered Beauty Companion</span>
        </div>

        <h1 class="animate-fade-up-delay-1 font-display text-5xl font-extrabold leading-[1.1] tracking-tight text-white sm:text-6xl lg:text-7xl">
          Your beauty,<br />
          <span class="text-gradient bg-gradient-to-r from-primary-light via-rose to-gold">
            fully understood.
          </span>
        </h1>

        <p class="animate-fade-up-delay-2 mt-6 text-lg leading-relaxed text-white/60 sm:text-xl">
          AI skincare specialists, haircare experts, and makeup advisors — all in one private, emotionally safe companion. Track products, build routines, analyze your skin, and get instant feedback that knows you.
        </p>

        <div class="animate-fade-up-delay-3 mt-10 flex flex-col gap-4 sm:flex-row">
          <a
            href="https://apps.apple.com/in/app/chitti-ai-skincare-expert/id6761166142"
            class="group inline-flex items-center justify-center gap-2.5 rounded-full bg-gradient-to-r from-primary to-primary-dark px-7 py-4 text-sm font-semibold text-white shadow-lg shadow-primary/25 transition-all hover:shadow-xl hover:shadow-primary/30 hover:brightness-110"
          >
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.05 20.28c-.98.95-2.05.8-3.08.35-1.09-.46-2.09-.48-3.24 0-1.44.62-2.2.44-3.06-.35C2.79 15.25 3.51 7.59 9.05 7.31c1.35.07 2.29.74 3.08.8 1.18-.24 2.31-.93 3.57-.84 1.51.12 2.65.72 3.4 1.8-3.12 1.87-2.38 5.98.48 7.13-.57 1.5-1.31 2.99-2.54 4.09zM12.03 7.25c-.15-2.23 1.66-4.07 3.74-4.25.29 2.58-2.34 4.5-3.74 4.25z"/>
            </svg>
            Download for iOS
          </a>
          <a
            href="https://chitti-public-assets-081196945050-ap-south-1-an.s3.ap-south-1.amazonaws.com/chitti-latest.apk"
            class="group inline-flex items-center justify-center gap-2.5 rounded-full border border-white/15 bg-white/5 px-7 py-4 text-sm font-semibold text-white backdrop-blur-sm transition-all hover:border-white/25 hover:bg-white/10"
          >
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor">
              <path d="M3.609 1.814L13.792 12 3.61 22.186a.996.996 0 0 1-.61-.92V2.734a1 1 0 0 1 .609-.92zm10.89 10.893l2.302 2.302-10.937 6.333 8.635-8.635zm3.199-3.199l2.302 2.302a1 1 0 0 1 0 1.38l-2.302 2.302L15.292 12l2.406-2.492zM5.864 2.658L16.8 9.008l-2.302 2.302L5.864 2.658z"/>
            </svg>
            Download for Android
          </a>
        </div>
      </div>

      <!-- Phone mockup carousel -->
      <div class="relative flex items-center justify-center lg:justify-end">
        <div class="animate-float relative">
          <!-- Phone frame -->
          <div class="phone-carousel relative h-[520px] w-[260px] rounded-[3rem] border border-white/10 bg-gradient-to-b from-bg-dark-card to-bg-dark shadow-2xl shadow-black/50 sm:h-[580px] sm:w-[290px]">
            <!-- Notch -->
            <div class="absolute top-3 left-1/2 -translate-x-1/2 z-10 h-7 w-28 rounded-full bg-black"></div>
            <!-- Screen with screenshots -->
            <div class="mx-3 mt-3 h-[calc(100%-1.5rem)] overflow-hidden rounded-[2.2rem]">
              <div class="phone-slides flex h-full transition-transform duration-700 ease-in-out">
                <img src="/images/screenshot-1.PNG" alt="Chitti Home — Chat, Product Check, and Vibe Check" class="h-full w-full flex-shrink-0 object-cover object-top" />
                <img src="/images/screenshot-2.PNG" alt="Chitti Skin Analysis — personalized skin concerns" class="h-full w-full flex-shrink-0 object-cover object-top" />
                <img src="/images/screenshot-3.PNG" alt="Chitti Style Feedback — AI style check" class="h-full w-full flex-shrink-0 object-cover object-top" />
              </div>
            </div>
            <!-- Carousel dots -->
            <div class="absolute -bottom-8 left-1/2 flex -translate-x-1/2 gap-2">
              <button class="phone-dot h-2 w-2 rounded-full bg-white/70 transition-all" data-index="0" aria-label="Show screenshot 1"></button>
              <button class="phone-dot h-2 w-2 rounded-full bg-white/30 transition-all" data-index="1" aria-label="Show screenshot 2"></button>
              <button class="phone-dot h-2 w-2 rounded-full bg-white/30 transition-all" data-index="2" aria-label="Show screenshot 3"></button>
            </div>
          </div>
          <!-- Glow behind phone -->
          <div class="absolute -inset-12 -z-10 rounded-full bg-gradient-to-br from-primary/20 via-iris/15 to-rose/20 blur-[80px]"></div>
        </div>
      </div>
    </div>
  </div>

  <!-- Transition to next section -->
  <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-white to-transparent"></div>
</section>

<script>
  const slides = document.querySelector('.phone-slides') as HTMLElement;
  const dots = document.querySelectorAll('.phone-dot');
  const total = 3;
  let current = 0;
  let interval: ReturnType<typeof setInterval>;

  function goTo(index: number) {
    current = index;
    slides.style.transform = `translateX(-${current * 100}%)`;
    dots.forEach((dot, i) => {
      dot.classList.toggle('bg-white/70', i === current);
      dot.classList.toggle('bg-white/30', i !== current);
    });
  }

  function next() {
    goTo((current + 1) % total);
  }

  function startAutoplay() {
    interval = setInterval(next, 3000);
  }

  dots.forEach((dot) => {
    dot.addEventListener('click', () => {
      clearInterval(interval);
      goTo(Number((dot as HTMLElement).dataset.index));
      startAutoplay();
    });
  });

  startAutoplay();
</script>
