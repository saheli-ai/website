<section class="relative bg-bg-dark py-24 sm:py-32 overflow-hidden">
  <!-- Subtle gradient orbs -->
  <div class="absolute inset-0 overflow-hidden">
    <div class="absolute -left-40 top-0 h-[350px] w-[350px] rounded-full bg-gradient-to-tr from-primary/15 to-transparent blur-[100px]"></div>
    <div class="absolute -right-40 bottom-0 h-[350px] w-[350px] rounded-full bg-gradient-to-bl from-iris/15 to-transparent blur-[100px]"></div>
  </div>

  <div class="relative mx-auto max-w-6xl px-6">
    <div class="mx-auto max-w-2xl text-center">
      <p class="mb-3 text-sm font-semibold uppercase tracking-widest text-primary">Your Privacy</p>
      <h2 class="font-display text-3xl font-bold tracking-tight text-white sm:text-4xl lg:text-5xl">
        Your face. Your data.<br />
        <span class="text-gradient bg-gradient-to-r from-primary via-sky to-iris">Your control.</span>
      </h2>
      <p class="mt-5 text-lg text-white/50">
        Beauty apps ask for your most personal data — your face. We believe that demands the highest standard of protection, not just promises.
      </p>
    </div>

    <div class="mt-16 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      <!-- No facial recognition -->
      <div class="group relative rounded-2xl border border-white/10 bg-white/5 p-8 backdrop-blur-sm transition-all duration-300 hover:border-primary/30 hover:bg-white/[0.08]">
        <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-2xl bg-gradient-to-br from-primary/20 to-primary/5 text-primary">
          <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M18.364 18.364A9 9 0 0 0 5.636 5.636m12.728 12.728A9 9 0 0 1 5.636 5.636m12.728 12.728L5.636 5.636" />
          </svg>
        </div>
        <h3 class="font-display text-lg font-bold text-white">No Facial Recognition</h3>
        <p class="mt-3 text-sm leading-relaxed text-white/50">
          We never identify you or anyone else from your photos. No faceprints. No biometrics. No facial geometry. Your face is analysed for beauty — nothing else.
        </p>
      </div>

      <!-- Zero AI training -->
      <div class="group relative rounded-2xl border border-white/10 bg-white/5 p-8 backdrop-blur-sm transition-all duration-300 hover:border-primary/30 hover:bg-white/[0.08]">
        <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-2xl bg-gradient-to-br from-iris/20 to-iris/5 text-iris">
          <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 3.104v5.714a2.25 2.25 0 0 1-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 0 1 4.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0 1 12 15a9.065 9.065 0 0 0-6.23.693L5 14.5m14.8.8l1.402 1.402c1.232 1.232.65 3.318-1.067 3.611A48.309 48.309 0 0 1 12 21c-2.773 0-5.491-.235-8.135-.687-1.718-.293-2.3-2.379-1.067-3.61L5 14.5" />
          </svg>
        </div>
        <h3 class="font-display text-lg font-bold text-white">Zero AI Training</h3>
        <p class="mt-3 text-sm leading-relaxed text-white/50">
          Your photos are never used to train any AI model — not ours, not OpenAI's, not anyone's. This is contractually enforced, not just a policy.
        </p>
      </div>

      <!-- Encrypted everything -->
      <div class="group relative rounded-2xl border border-white/10 bg-white/5 p-8 backdrop-blur-sm transition-all duration-300 hover:border-primary/30 hover:bg-white/[0.08]">
        <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-2xl bg-gradient-to-br from-sky/20 to-sky/5 text-sky">
          <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 1 0-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 0 0 2.25-2.25v-6.75a2.25 2.25 0 0 0-2.25-2.25H6.75a2.25 2.25 0 0 0-2.25 2.25v6.75a2.25 2.25 0 0 0 2.25 2.25z" />
          </svg>
        </div>
        <h3 class="font-display text-lg font-bold text-white">Encrypted Everything</h3>
        <p class="mt-3 text-sm leading-relaxed text-white/50">
          AES-256 encryption at rest. TLS 1.3 in transit. Row-level security so only you can access your data. Your photos never touch our logs or analytics.
        </p>
      </div>

      <!-- Auto-delete -->
      <div class="group relative rounded-2xl border border-white/10 bg-white/5 p-8 backdrop-blur-sm transition-all duration-300 hover:border-primary/30 hover:bg-white/[0.08]">
        <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-2xl bg-gradient-to-br from-rose/20 to-rose/5 text-rose">
          <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0z" />
          </svg>
        </div>
        <h3 class="font-display text-lg font-bold text-white">Auto-Delete by Design</h3>
        <p class="mt-3 text-sm leading-relaxed text-white/50">
          Vibe Check photos are never stored. Makeup photos auto-delete in 7 days. We keep only what you need, for only as long as you need it.
        </p>
      </div>

      <!-- You own your data -->
      <div class="group relative rounded-2xl border border-white/10 bg-white/5 p-8 backdrop-blur-sm transition-all duration-300 hover:border-primary/30 hover:bg-white/[0.08]">
        <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-2xl bg-gradient-to-br from-gold/20 to-gold/5 text-gold">
          <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 5.25a3 3 0 0 1 3 3m3 0a6 6 0 0 1-7.029 5.912c-.563-.097-1.159.026-1.563.43L10.5 17.25H8.25v2.25H6v2.25H2.25v-2.818c0-.597.237-1.17.659-1.591l6.499-6.499c.404-.404.527-1 .43-1.563A6 6 0 1 1 21.75 8.25z" />
          </svg>
        </div>
        <h3 class="font-display text-lg font-bold text-white">You Own Your Data</h3>
        <p class="mt-3 text-sm leading-relaxed text-white/50">
          Delete your account from the app at any time. Every photo, conversation, and preference is permanently erased. No hoops, no waiting.
        </p>
      </div>

      <!-- Never sold -->
      <div class="group relative rounded-2xl border border-white/10 bg-white/5 p-8 backdrop-blur-sm transition-all duration-300 hover:border-primary/30 hover:bg-white/[0.08]">
        <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-2xl bg-gradient-to-br from-primary/20 to-primary/5 text-primary">
          <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z" />
          </svg>
        </div>
        <h3 class="font-display text-lg font-bold text-white">Never Sold. Never Shared.</h3>
        <p class="mt-3 text-sm leading-relaxed text-white/50">
          Your data is never sold, rented, or shared with advertisers, data brokers, or marketers. We make money from the app, not from your data.
        </p>
      </div>
    </div>

    <div class="mt-12 text-center">
      <a
        href="/privacy"
        class="inline-flex items-center gap-2 text-sm font-medium text-primary transition-colors hover:text-primary-light"
      >
        Read our full Privacy Policy
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" /></svg>
      </a>
    </div>
  </div>
</section>
