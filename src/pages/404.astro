---
import PageLayout from '../layouts/PageLayout.astro';
---

<PageLayout title="Page Not Found — Chitti">
  <section class="flex min-h-[60vh] items-center justify-center py-24">
    <div class="text-center">
      <p class="text-7xl font-extrabold text-primary/20">404</p>
      <h1 class="mt-4 text-2xl font-bold text-text">Page not found</h1>
      <p class="mt-3 text-text-light">
        Sorry, we couldn't find the page you're looking for.
      </p>
      <a
        href="/"
        class="mt-8 inline-flex rounded-full bg-primary px-6 py-3 text-sm font-semibold text-white transition-all hover:bg-primary-dark hover:shadow-lg"
      >
        Back to home
      </a>
    </div>
  </section>
</PageLayout>
