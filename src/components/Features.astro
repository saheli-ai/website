---
const features = [
  {
    title: 'AI Specialists',
    description: 'Chat with dedicated skincare, haircare, and makeup experts. Every conversation knows your products, routines, and skin analysis — so advice is truly personal from message one.',
    gradient: 'from-primary/20 to-sky/20',
    iconBg: 'from-primary to-sky',
    icon: `<svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09zm8.446-7.189L18 9.75l-.259-1.035a3.375 3.375 0 0 0-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 0 0 2.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 0 0 2.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 0 0-2.456 2.456z" /></svg>`,
  },
  {
    title: 'Skin Analysis',
    description: 'Multi-angle photo capture with 13 detailed skin attributes — from hydration and texture to dark spots and pore size. Results seed every future conversation.',
    gradient: 'from-rose/20 to-accent/20',
    iconBg: 'from-rose to-accent',
    icon: `<svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.182 15.182a4.5 4.5 0 0 1-6.364 0M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0zM9.75 9.75c0 .414-.168.75-.375.75S9 10.164 9 9.75 9.168 9 9.375 9s.375.336.375.75zm-.375 0h.008v.015h-.008V9.75zm5.625 0c0 .414-.168.75-.375.75s-.375-.336-.375-.75.168-.75.375-.75.375.336.375.75zm-.375 0h.008v.015h-.008V9.75z" /></svg>`,
  },
  {
    title: 'Vibe Check',
    description: 'Your smart mirror. Open the camera, face detected, instant AI feedback in under 5 seconds — with spatial labels overlaid right where they matter.',
    gradient: 'from-iris/20 to-primary/20',
    iconBg: 'from-iris to-primary',
    icon: `<svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" /></svg>`,
  },
  {
    title: 'Product Tracking',
    description: 'Mention products in conversation and Chitti automatically adds them to your inventory. Build your complete beauty collection without filling out a single form.',
    gradient: 'from-gold/20 to-accent/20',
    iconBg: 'from-gold to-accent-dark',
    icon: `<svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M20.25 7.5l-.625 10.632a2.25 2.25 0 0 1-2.247 2.118H6.622a2.25 2.25 0 0 1-2.247-2.118L3.75 7.5M10 11.25h4M3.375 7.5h17.25c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125z" /></svg>`,
  },
  {
    title: 'Routines & Trials',
    description: 'Build AM/PM skincare routines with proper step ordering. Test new products with structured 28-day trials and guided check-ins — like having a dermatologist on speed dial.',
    gradient: 'from-sky/20 to-iris/20',
    iconBg: 'from-sky to-iris',
    icon: `<svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0z" /></svg>`,
  },
  {
    title: 'Progress Tracking',
    description: 'Capture progress photos over time and watch your skin transform. Before/after comparisons with AI trend analysis that correlates changes with the products you use.',
    gradient: 'from-primary/20 to-rose/20',
    iconBg: 'from-primary to-rose',
    icon: `<svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18L9 11.25l4.306 4.306a11.95 11.95 0 0 1 5.814-5.518l2.74-1.22m0 0l-5.94-2.281m5.94 2.28l-2.28 5.941" /></svg>`,
  },
];
---

<section id="features" class="relative bg-white py-24 sm:py-32">
  <div class="mx-auto max-w-6xl px-6">
    <div class="mx-auto max-w-2xl text-center">
      <p class="mb-3 text-sm font-semibold uppercase tracking-widest text-primary">Platform</p>
      <h2 class="font-display text-3xl font-bold tracking-tight text-text sm:text-4xl lg:text-5xl">
        A complete beauty companion,<br />
        <span class="text-gradient bg-gradient-to-r from-primary via-iris to-rose">not just another filter.</span>
      </h2>
      <p class="mt-5 text-lg text-text-light">
        Specialists, analysis, routines, trials, and progress — all personalized to you.
      </p>
    </div>

    <div class="mt-20 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {features.map((feature, i) => (
        <div
          class="group relative overflow-hidden rounded-2xl border border-black/5 bg-white p-8 transition-all duration-300 hover:-translate-y-1 hover:shadow-xl hover:shadow-black/5"
          style={`animation-delay: ${i * 0.08}s;`}
        >
          {/* Gradient background on hover */}
          <div class={`absolute inset-0 bg-gradient-to-br ${feature.gradient} opacity-0 transition-opacity duration-300 group-hover:opacity-100`}></div>

          <div class="relative">
            {/* Icon */}
            <div class={`mb-6 flex h-12 w-12 items-center justify-center rounded-2xl bg-gradient-to-br ${feature.iconBg} text-white shadow-lg`}>
              <Fragment set:html={feature.icon} />
            </div>

            <h3 class="font-display text-lg font-bold text-text">{feature.title}</h3>
            <p class="mt-3 text-sm leading-relaxed text-text-light">{feature.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
