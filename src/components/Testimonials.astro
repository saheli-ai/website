---
const testimonials = [
  {
    quote: "I built my full AM/PM routine with Chitti and started a retinol trial. The guided check-ins actually kept me consistent for the first time ever.",
    name: "Priya S.",
    role: "Routine builder",
    gradient: 'from-rose/10 to-accent/10',
    borderColor: 'hover:border-rose/20',
  },
  {
    quote: "The skin analysis told me things I never noticed — texture, hydration, pore size. Now every product recommendation actually makes sense for my skin.",
    name: "Ananya K.",
    role: "Skincare enthusiast",
    gradient: 'from-primary/10 to-sky/10',
    borderColor: 'hover:border-primary/20',
  },
  {
    quote: "I just open Vibe Check before heading out — instant feedback in seconds. And the haircare specialist helped me fix my frizz routine completely.",
    name: "Meera R.",
    role: "Working professional",
    gradient: 'from-iris/10 to-gold/10',
    borderColor: 'hover:border-iris/20',
  },
];
---

<section class="relative overflow-hidden bg-gradient-to-b from-white via-bg-cream to-bg-blush py-24 sm:py-32">
  <div class="mx-auto max-w-6xl px-6">
    <div class="mx-auto max-w-2xl text-center">
      <p class="mb-3 text-sm font-semibold uppercase tracking-widest text-accent-dark">Testimonials</p>
      <h2 class="font-display text-3xl font-bold tracking-tight text-text sm:text-4xl lg:text-5xl">
        Loved by women who<br />
        <span class="text-gradient bg-gradient-to-r from-accent-dark via-rose to-iris">love themselves</span>
      </h2>
    </div>

    <div class="mt-16 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {testimonials.map((t) => (
        <div class={`group relative overflow-hidden rounded-3xl border border-black/5 bg-white p-8 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-xl ${t.borderColor}`}>
          {/* Background gradient on hover */}
          <div class={`absolute inset-0 bg-gradient-to-br ${t.gradient} opacity-0 transition-opacity duration-300 group-hover:opacity-100`}></div>

          <div class="relative">
            {/* Stars */}
            <div class="mb-5 flex gap-1 text-gold">
              {[...Array(5)].map(() => (
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M10.788 3.21c.448-1.077 1.976-1.077 2.424 0l2.082 5.007 5.404.433c1.164.093 1.636 1.545.749 2.305l-4.117 3.527 1.257 5.273c.271 1.136-.964 2.033-1.96 1.425L12 18.354 7.373 21.18c-.996.608-2.231-.29-1.96-1.425l1.257-5.273-4.117-3.527c-.887-.76-.415-2.212.749-2.305l5.404-.433 2.082-5.006z" />
                </svg>
              ))}
            </div>

            <blockquote class="text-base leading-relaxed text-text-light">
              &ldquo;{t.quote}&rdquo;
            </blockquote>

            <div class="mt-6 flex items-center gap-3">
              <div class="flex h-10 w-10 items-center justify-center rounded-full bg-gradient-to-br from-primary to-iris text-sm font-bold text-white">
                {t.name.charAt(0)}
              </div>
              <div>
                <p class="text-sm font-semibold text-text">{t.name}</p>
                <p class="text-xs text-text-muted">{t.role}</p>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
