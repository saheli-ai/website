---
import { getCollection } from 'astro:content';
import PageLayout from '../../layouts/PageLayout.astro';
import BlogCard from '../../components/BlogCard.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<PageLayout title="Blog — Chitti" description="Tips, insights, and updates from the Chitti team on beauty, skincare, and self-confidence.">

  <section class="py-24 sm:py-32">
    <div class="mx-auto max-w-4xl px-6">
      <div class="mb-12">
        <h1 class="text-3xl font-extrabold tracking-tight text-text sm:text-4xl">Blog</h1>
        <p class="mt-3 text-lg text-text-light">
          Tips, insights, and updates on beauty, skincare, and self-confidence.
        </p>
      </div>

      {posts.length === 0 ? (
        <div class="rounded-2xl border border-primary/10 bg-bg-cream p-12 text-center">
          <p class="text-text-light">No posts yet. Check back soon!</p>
        </div>
      ) : (
        <div class="grid gap-6">
          {posts.map((post) => (
            <BlogCard
              title={post.data.title}
              description={post.data.description}
              pubDate={post.data.pubDate}
              author={post.data.author}
              slug={post.id}
              tags={post.data.tags}
            />
          ))}
        </div>
      )}
    </div>
  </section>

</PageLayout>
