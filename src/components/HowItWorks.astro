---
const steps = [
  {
    number: '01',
    title: 'Set Up Your Profile',
    description: 'Run a skin analysis, add your products by chatting naturally, and Chitti builds your complete beauty context automatically.',
    icon: `<svg class="h-8 w-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6.827 6.175A2.31 2.31 0 0 1 5.186 7.23c-.38.054-.757.112-1.134.175C2.999 7.58 2.25 8.507 2.25 9.574V18a2.25 2.25 0 0 0 2.25 2.25h15A2.25 2.25 0 0 0 21.75 18V9.574c0-1.067-.75-1.994-1.802-2.169a47.865 47.865 0 0 0-1.134-.175 2.31 2.31 0 0 1-1.64-1.055l-.822-1.316a2.192 2.192 0 0 0-1.736-1.039 48.774 48.774 0 0 0-5.232 0 2.192 2.192 0 0 0-1.736 1.039l-.821 1.316z" /><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 12.75a4.5 4.5 0 1 1-9 0 4.5 4.5 0 0 1 9 0z" /></svg>`,
    gradient: 'from-rose to-accent',
  },
  {
    number: '02',
    title: 'Talk to Specialists',
    description: 'Chat with AI skincare, haircare, or makeup experts who already know your products, routines, and skin — from the very first message.',
    icon: `<svg class="h-8 w-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09zm8.446-7.189L18 9.75l-.259-1.035a3.375 3.375 0 0 0-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 0 0 2.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 0 0 2.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 0 0-2.456 2.456z" /></svg>`,
    gradient: 'from-iris to-primary',
  },
  {
    number: '03',
    title: 'Track & Improve',
    description: 'Build routines, test new products with structured trials, capture progress photos, and watch your skin transform over time.',
    icon: `<svg class="h-8 w-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M7.5 8.25h9m-9 3H12m-9.75 1.51c0 1.6 1.123 2.994 2.707 3.227 1.129.166 2.27.293 3.423.379.35.026.67.21.865.501L12 21l2.755-4.133a1.14 1.14 0 0 1 .865-.501 48.172 48.172 0 0 0 3.423-.379c1.584-.233 2.707-1.626 2.707-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0 0 12 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018z" /></svg>`,
    gradient: 'from-primary to-sky',
  },
];
---

<section id="how-it-works" class="relative overflow-hidden bg-bg-dark py-24 sm:py-32">
  <!-- Background orbs -->
  <div class="absolute left-1/2 top-0 h-[300px] w-[600px] -translate-x-1/2 rounded-full bg-gradient-to-b from-primary/10 to-transparent blur-[100px]"></div>

  <div class="relative mx-auto max-w-6xl px-6">
    <div class="mx-auto max-w-2xl text-center">
      <p class="mb-3 text-sm font-semibold uppercase tracking-widest text-primary-light">How It Works</p>
      <h2 class="font-display text-3xl font-bold tracking-tight text-white sm:text-4xl lg:text-5xl">
        Three steps to feeling<br />
        <span class="text-gradient bg-gradient-to-r from-primary-light via-gold to-rose">amazing</span>
      </h2>
    </div>

    <div class="mt-20 grid gap-8 lg:gap-12 lg:grid-cols-3">
      {steps.map((step, i) => (
        <div class="group relative">
          {/* Card */}
          <div class="relative overflow-hidden rounded-3xl border border-white/5 bg-bg-dark-card p-8 transition-all duration-300 hover:border-white/10 hover:shadow-2xl hover:shadow-primary/5 sm:p-10">
            {/* Number */}
            <div class="mb-8 font-display text-6xl font-extrabold text-white/5">
              {step.number}
            </div>

            {/* Icon circle */}
            <div class={`mb-6 flex h-16 w-16 items-center justify-center rounded-2xl bg-gradient-to-br ${step.gradient} text-white shadow-lg`}>
              <Fragment set:html={step.icon} />
            </div>

            <h3 class="font-display text-2xl font-bold text-white">{step.title}</h3>
            <p class="mt-3 leading-relaxed text-white/50">{step.description}</p>

            {/* Gradient line at bottom */}
            <div class={`mt-8 h-1 w-16 rounded-full bg-gradient-to-r ${step.gradient} opacity-50 transition-all duration-300 group-hover:w-full group-hover:opacity-100`}></div>
          </div>

          {/* Arrow connector (desktop) */}
          {i < 2 && (
            <div class="absolute -right-10 top-1/2 z-10 hidden -translate-y-1/2 lg:block">
              <svg class="h-8 w-8 text-white/10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
              </svg>
            </div>
          )}
        </div>
      ))}
    </div>
  </div>
</section>
